# =============================================================================
# MiKiwi - Variables de Entorno para Docker
# Copiar a .env y configurar valores reales
# =============================================================================

# PostgreSQL
POSTGRES_DB=mikiwi
POSTGRES_USER=mikiwi_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
POSTGRES_PORT=5432

# Clave de encriptación para pgcrypto (32 caracteres)
DB_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32_CHAR

# pgAdmin
PGADMIN_EMAIL=admin@mikiwi.local
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050

# Retención de backups
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_RETENTION_MONTHS=12

# Contraseñas de roles (configurar en 06_security_roles.sql)
DB_APP_PASSWORD=CHANGE_ME_APP_ROLE_PASSWORD
DB_READONLY_PASSWORD=CHANGE_ME_READONLY_PASSWORD
DB_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
